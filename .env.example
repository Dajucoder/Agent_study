# ===== LangChain 学习项目环境变量示例 =====
# 复制本文件为 .env 并填入真实值：cp .env.example .env

# ---- OpenAI ----
# 必填：你的 OpenAI API Key
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 可选：自定义 API 基址（使用代理或第三方兼容服务时填写）
# OPENAI_API_BASE=https://api.openai.com/v1

# 可选：指定默认模型（在代码中也可覆盖）
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# 可选：LLM 运行时参数（get_llm 未显式传参时读取；缺省 0.7 / 30 / 2）
# OPENAI_TEMPERATURE=0.7
# OPENAI_TIMEOUT=30
# OPENAI_MAX_RETRIES=2
# OPENAI_EMBEDDING_TIMEOUT=30

# ---- LangSmith 可观测性（可选）----
# 开启后可在 https://smith.langchain.com 查看链路追踪
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=langchain-study

# ---- 本地向量库路径（可选）----
# CHROMA_PERSIST_DIR=./data/chroma

# ---- 分支模型（按需）----
# 通义千问 DashScope 兼容模式（examples/08_qwen.py 使用）
# DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_MODEL=qwen-plus

# 本地 Ollama 模型（examples/07_ollama_local.py 使用）
# OLLAMA_BASE_URL=http://localhost:11434
